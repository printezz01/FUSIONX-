# ═══════════════════════════════════════════════════
# Sentinel AI — Environment Variables
# Copy this file to .env and fill in your values
# PRIORITY: Groq (free) → Gemini (free) → Claude (paid) → Demo mode
# ═══════════════════════════════════════════════════

# Groq API (FREE — get key at https://console.groq.com)
GROQ_API_KEY=

# Google Gemini API (FREE — get key at https://aistudio.google.com)
GOOGLE_API_KEY=

# Anthropic Claude API (optional — paid fallback)
ANTHROPIC_API_KEY=

# Voyage AI Embeddings (primary)
VOYAGE_API_KEY=

# OpenAI Embeddings (fallback — only if Voyage unavailable)
OPENAI_API_KEY=

# Supabase (optional — app works with in-memory fallback)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# NVD API (free tier)
NVD_API_KEY=
