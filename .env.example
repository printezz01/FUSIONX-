# ═══════════════════════════════════════════════════
# Sentinel AI — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# Anthropic Claude API (required)
ANTHROPIC_API_KEY=

# Voyage AI Embeddings (primary)
VOYAGE_API_KEY=

# OpenAI Embeddings (fallback — only if Voyage unavailable)
OPENAI_API_KEY=

# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# NVD API (free tier)
NVD_API_KEY=
